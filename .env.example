# Copy this file to .env and fill in your key.
# .env is ignored by git.

OPENAI_API_KEY=
AI_ARCHITECT_MODEL=gpt-5-nano
AI_ARCHITECT_LLM_PROVIDER=openai-compatible
AI_ARCHITECT_LLM_BASE_URL=https://api.openai.com/v1
AI_ARCHITECT_LLM_TIMEOUT_SECONDS=90
AI_ARCHITECT_LLM_MAX_OUTPUT_TOKENS=3500

ENVIRONMENT=local

# Optional durable project history.
# Set this to your Prisma Postgres pooled/direct connection URL in production.
PRISMA_DATABASE_URL=
